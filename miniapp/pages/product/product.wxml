<!-- 商品管理列表 -->
<wxs module="util" src="../../utils/util.wxs"></wxs>
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索商品名称" bindinput="onSearch" value="{{searchName}}"
           confirm-type="search" bindconfirm="doSearch" />
    <button class="btn-primary search-btn" bindtap="doSearch" size="mini">搜索</button>
  </view>

  <!-- 分类标签 -->
  <scroll-view scroll-x class="category-tabs" wx:if="{{categories.length > 0}}">
    <view class="tab {{currentCategoryId === null ? 'active' : ''}}" bindtap="onCategoryTap" data-id="{{null}}">全部</view>
    <view class="tab {{currentCategoryId === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id"
          bindtap="onCategoryTap" data-id="{{item.id}}">{{item.name}}</view>
  </scroll-view>

  <!-- 商品列表 -->
  <view class="product-list">
    <view class="card product-item" wx:for="{{products}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="flex-between">
        <view class="flex-col" style="flex:1">
          <view class="flex-row">
            <text class="text-bold text-lg">{{item.name}}</text>
            <text class="tag tag-info mr-10">{{item.priceTypeText}}</text>
          </view>
          <view class="mt-10 flex-row">
            <text class="text-primary text-bold mr-20">¥{{item.formattedPrice}}/{{item.unit}}</text>
            <text class="text-sm text-muted">库存: {{item.stock}}{{item.unit}}</text>
          </view>
        </view>
        <view>
          <button class="{{item.status === 1 ? 'btn-danger' : 'btn-primary'}}" size="mini"
                  catchtap="toggleStatus" data-id="{{item.id}}" data-status="{{item.status}}">
            {{item.status === 1 ? '下架' : '上架'}}
          </button>
        </view>
      </view>
      <!-- 库存预警 -->
      <view class="mt-10" wx:if="{{item.stock <= item.warningStock}}">
        <text class="tag tag-danger">库存不足</text>
      </view>
    </view>

    <!-- 分页状态 -->
    <view wx:if="{{loading}}" class="text-center mt-30">
      <text class="text-muted">加载中...</text>
    </view>
    <view wx:if="{{hasMore && !loading}}" class="text-center mt-30" bindtap="loadMore">
      <button class="btn-primary" size="mini">加载更多 ({{page}}/{{totalPages}})</button>
    </view>
    <view wx:if="{{!hasMore && products.length > 0}}" class="text-center mt-30">
      <text class="text-muted">共 {{total}} 条，已全部加载</text>
    </view>
    <view wx:if="{{!loading && products.length === 0}}" class="text-center mt-30">
      <text class="text-muted">暂无商品，点击右下角 + 添加</text>
    </view>
  </view>

  <!-- 新增按钮 -->
  <view class="float-btn" bindtap="goAdd">
    <text class="float-btn-text">+</text>
  </view>
</view>
