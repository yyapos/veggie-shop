.container { padding: 24rpx; background: #f5f5f5; min-height: 100vh; }

/* 面包屑 */
.breadcrumb { padding: 12rpx 0; margin-bottom: 20rpx; display: flex; align-items: center; flex-wrap: wrap; }
.bc-item { color: #07c160; font-size: 26rpx; padding: 6rpx 0; }
.bc-sep { color: #ccc; margin: 0 10rpx; font-size: 26rpx; }
.bc-current { color: #333; font-size: 26rpx; font-weight: 600; }

/* 分类卡片网格 */
.cat-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.cat-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.cat-body {
  padding: 30rpx 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
}
.cat-icon { font-size: 56rpx; margin-bottom: 10rpx; }
.cat-title { font-size: 28rpx; font-weight: 600; color: #333; }
.cat-desc { font-size: 22rpx; color: #bbb; margin-top: 4rpx; }
.cat-actions {
  display: flex;
  padding: 10rpx 12rpx;
  gap: 6rpx;
  justify-content: center;
}

/* 商品列表 */
.product-item { border-left: 5rpx solid #07c160; }
.price { font-size: 32rpx; font-weight: 700; color: #e74c3c; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }

/* 添加按钮 */
.btn-add {
  width: 100%;
  margin-top: 24rpx;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 14rpx;
  padding: 22rpx 0;
  border: none;
}

/* 通用 */
.mb-15 { margin-bottom: 15rpx; }
.mt-5 { margin-top: 5rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.text-center { text-align: center; }
.text-bold { font-weight: 600; color: #333; }
.text-lg { font-size: 32rpx; }
.text-muted { font-size: 26rpx; color: #999; }
.text-sm { font-size: 24rpx; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-row { display: flex; align-items: center; flex-wrap: wrap; }

.card { background: #fff; border-radius: 14rpx; padding: 22rpx; margin-bottom: 14rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05); }

.tag { display: inline-block; padding: 3rpx 12rpx; font-size: 22rpx; border-radius: 6rpx; background: #e8f8ef; color: #07c160; margin-right: 10rpx; }

button { border-radius: 10rpx; font-size: 24rpx; line-height: 1.4; }
.btn-primary { background: #07c160; color: #fff; border: none; }
.btn-cancel { background: #f0f0f0; color: #666; border: none; }
.btn-edit { background: #f0f0f0; color: #333; border: none; }
.btn-del { background: #fff0f0; color: #fa5151; border: none; }
.btn-sm { padding: 6rpx 18rpx; font-size: 24rpx; }

/* 弹窗 */
.modal { position: fixed; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.45); display: flex; align-items: center; justify-content: center; z-index: 999; }
.modal-content { width: 84%; max-width: 600rpx; }
.modal-content .card { margin-bottom: 0; }
.form-group { margin-bottom: 20rpx; }
.form-label { font-size: 28rpx; color: #666; margin-bottom: 8rpx; }
.field-input { width: 100%; height: 72rpx; background: #f7f7f7; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; box-sizing: border-box; }

/* 表情选择器 */
.form-icon-preview { font-size: 36rpx; margin-left: 10rpx; }
.emoji-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.emoji-item {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}
.emoji-selected {
  background: #e8f8ef;
  border-color: #07c160;
}
