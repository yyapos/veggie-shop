.container {
  padding: 20rpx;
}
.mb-10 { margin-bottom: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-10 { margin-top: 10rpx; }
.ml-20 { margin-left: 20rpx; }

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.text-bold { font-size: 30rpx; font-weight: 600; color: #333; }
.text-lg { font-size: 32rpx; }
.text-muted { font-size: 26rpx; color: #999; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-row { display: flex; align-items: center; flex-wrap: wrap; }

.sub-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.sub-item:last-child { border-bottom: none; }

/* 弹窗 */
.modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-content { width: 86%; max-width: 600rpx; }
.modal-content .card { margin-bottom: 0; }

.form-group { margin-bottom: 20rpx; }
.form-label { font-size: 28rpx; color: #666; margin-bottom: 8rpx; }
.form-input {
  width: 100%;
  height: 72rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

button {
  font-size: 26rpx;
  border-radius: 10rpx;
  margin-left: 8rpx;
}

.btn-primary {
  background: #07c160;
  color: #fff;
  border: none;
}
.btn-primary[type="warn"] { background: #fa5151; }
.btn-cancel {
  background: #f0f0f0;
  color: #666;
  border: none;
}
.btn-sm {
  padding: 6rpx 20rpx;
  font-size: 24rpx;
}

.category-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.category-row:last-child { border-bottom: none; }

.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  font-size: 22rpx;
  border-radius: 6rpx;
  background: #e8f8ef;
  color: #07c160;
  margin-right: 8rpx;
}

.btn-group { display: flex; gap: 10rpx; }

/* 表情选择器 */
.form-icon-preview { font-size: 36rpx; margin-left: 10rpx; }
.emoji-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.emoji-item {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}
.emoji-selected {
  background: #e8f8ef;
  border-color: #07c160;
}
