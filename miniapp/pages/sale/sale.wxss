.stats-bar {
  padding: 28rpx;
}

.selector {
  line-height: 80rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.amount-display {
  background: #f0fff4;
  border-radius: 8rpx;
  padding: 20rpx;
  text-align: center;
  margin-top: 16rpx;
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border: 2rpx solid #dcdcdc;
  border-radius: 8rpx;
  margin: 0 8rpx;
  font-size: 28rpx;
}

.type-btn:first-child { margin-left: 0; }
.type-btn:last-child { margin-right: 0; }

.type-btn.active {
  border-color: #07c160;
  background: #f0fff4;
  color: #07c160;
  font-weight: bold;
}

/* 商品选择弹窗 */
.picker-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.picker-content {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 65vh;
  overflow: hidden;
}

.picker-header {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-body {
  max-height: 50vh;
}

.picker-item {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}
