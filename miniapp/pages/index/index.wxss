.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.overview-section {
  background: linear-gradient(135deg, #07c160, #05a050);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.overview-section .section-title {
  color: rgba(255,255,255,0.8);
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

.overview-grid {
  display: flex;
  flex-wrap: wrap;
}

.overview-item {
  width: 50%;
  padding: 10rpx 0;
}

.overview-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff !important;
}

.overview-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}

.quick-actions {
  padding: 24rpx;
}

.action-grid {
  display: flex;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
}

.action-icon {
  font-size: 52rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

.warning-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.warning-item:last-child {
  border-bottom: none;
}
